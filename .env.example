NODE_ENV=development
HOST=0.0.0.0
PORT=5000
PUBLIC_API_BASE_URL=http://localhost:5000
PUBLIC_WEB_APP_URL=http://localhost:3000
TRUST_PROXY=false

MONGO_URI=mongodb://127.0.0.1:27017/astronomy-pathshala
MONGO_FALLBACK_URI=
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_MIN_POOL_SIZE=0
MONGO_MAX_POOL_SIZE=10

JWT_ACCESS_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-at-least-32-random-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_SALT_ROUNDS=12
RESET_TOKEN_EXPIRES_MINUTES=10
OTP_EXPIRES_MINUTES=10

CORS_ORIGIN=http://localhost:3000,http://localhost:5173
JSON_BODY_LIMIT=1mb
URLENCODED_BODY_LIMIT=1mb
URLENCODED_PARAMETER_LIMIT=100
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
OTP_RATE_LIMIT_WINDOW_MS=3600000
OTP_RATE_LIMIT_MAX=5

EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=no-reply@astronomypathshala.com

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

BKASH_BASE_URL=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_CALLBACK_URL=
BKASH_CALLBACK_SUCCESS=
BKASH_CALLBACK_FAIL=
BKASH_CALLBACK_CANCEL=
BKASH_WEBHOOK=
BKASH_TOKEN_CACHE_TTL=3600

LOG_LEVEL=debug
REQUIRE_EXTERNAL_SERVICES=false
SERVER_KEEP_ALIVE_TIMEOUT_MS=65000
SERVER_HEADERS_TIMEOUT_MS=66000
SERVER_REQUEST_TIMEOUT_MS=300000
SHUTDOWN_GRACE_PERIOD_MS=10000
