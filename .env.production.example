NODE_ENV=production
HOST=0.0.0.0
PORT=5000
PUBLIC_API_BASE_URL=https://api.astronomypathshala.com
PUBLIC_WEB_APP_URL=https://www.astronomypathshala.com
TRUST_PROXY=1

MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/astronomy-pathshala
MONGO_FALLBACK_URI=
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_MIN_POOL_SIZE=0
MONGO_MAX_POOL_SIZE=20

JWT_ACCESS_SECRET=replace-with-64-plus-random-characters
JWT_REFRESH_SECRET=replace-with-a-different-64-plus-random-value
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

BCRYPT_SALT_ROUNDS=12
RESET_TOKEN_EXPIRES_MINUTES=10
OTP_EXPIRES_MINUTES=10

CORS_ORIGIN=https://www.astronomypathshala.com,https://admin.astronomypathshala.com
JSON_BODY_LIMIT=1mb
URLENCODED_BODY_LIMIT=1mb
URLENCODED_PARAMETER_LIMIT=100
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=500
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
OTP_RATE_LIMIT_WINDOW_MS=3600000
OTP_RATE_LIMIT_MAX=5

EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=replace-with-smtp-user
EMAIL_PASS=replace-with-smtp-password
EMAIL_FROM=no-reply@astronomypathshala.com

CLOUDINARY_CLOUD_NAME=replace-with-cloud-name
CLOUDINARY_API_KEY=replace-with-api-key
CLOUDINARY_API_SECRET=replace-with-api-secret

BKASH_BASE_URL=https://tokenized.pay.bka.sh/v1.2.0-beta
BKASH_USERNAME=replace-with-bkash-username
BKASH_PASSWORD=replace-with-bkash-password
BKASH_APP_KEY=replace-with-bkash-app-key
BKASH_APP_SECRET=replace-with-bkash-app-secret
BKASH_CALLBACK_URL=https://api.astronomypathshala.com/api/v1/payments/bkash/callback
BKASH_CALLBACK_SUCCESS=https://www.astronomypathshala.com/payment/success
BKASH_CALLBACK_FAIL=https://www.astronomypathshala.com/payment/fail
BKASH_CALLBACK_CANCEL=https://www.astronomypathshala.com/payment/cancel
BKASH_WEBHOOK=https://api.astronomypathshala.com/api/v1/payments/bkash/callback
BKASH_TOKEN_CACHE_TTL=3600

LOG_LEVEL=info
REQUIRE_EXTERNAL_SERVICES=true
SERVER_KEEP_ALIVE_TIMEOUT_MS=65000
SERVER_HEADERS_TIMEOUT_MS=66000
SERVER_REQUEST_TIMEOUT_MS=300000
SHUTDOWN_GRACE_PERIOD_MS=10000
