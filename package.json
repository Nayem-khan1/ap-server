{
  "name": "astronomy-pathshala-server",
  "version": "1.0.0",
  "description": "LMS Authentication + Public API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "seed": "tsx scripts/seed.ts",
    "integration:check": "cd .. && node server/scripts/integration-check.cjs"
  },
  "keywords": [
    "express",
    "lms",
    "mongodb",
    "typescript"
  ],
  "license": "ISC",
  "dependencies": {
    "axios": "^1.11.0",
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.7.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^8.1.0",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "mongoose": "^8.19.2",
    "morgan": "^1.10.1",
    "nodemailer": "^7.0.10",
    "winston": "^3.18.3",
    "xss-clean": "^0.1.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.18.6",
    "@types/nodemailer": "^7.0.3",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
